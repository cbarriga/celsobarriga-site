---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPost from "../../../components/BlogPost.astro";
import TagFilterBar from "../../../components/TagFilterBar.astro";
import { sortByDate } from "../../../components/sortByDate";
import { buildTagPaths } from "../../../scripts/collections";
import { formatReadingTime } from "../../../scripts/utils";
import getReadingTime from "reading-time";

export async function getStaticPaths() {
  const entries = await getCollection("journal");
  return buildTagPaths(entries, "journal");
}

const { tag } = Astro.params;
const { posts, collectionSlug } = Astro.props;
const allEntries = await getCollection("journal");
const allTags = [...new Set(allEntries.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title={`${tag} — ${collectionSlug}`} is404Page={false}>
  <TagFilterBar tags={allTags} activeTag={tag} basePath={collectionSlug} />
  {
    posts
      .sort(sortByDate)
      .map((post) => (
        <BlogPost
          url={`/${collectionSlug}/${post.id}/`}
          image={post.data?.image?.src || ""}
          alt={post.data?.image?.alt || ""}
          title={post.data?.title || ""}
          description={post.data?.description || ""}
          pubDate={post.data?.pubDate || ""}
          positionx={post.data?.image?.positionx || ""}
          positiony={post.data?.image?.positiony || ""}
          minutesRead={formatReadingTime(getReadingTime(post.body ?? "").time)}
          tags={post.data.tags}
        />
      ))
  }
</BaseLayout>
