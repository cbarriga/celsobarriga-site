---
---
<button
  id="theme-toggle-btn"
  class="w-7.5 h-7.5 bg-transparent border-0 p-0 cursor-pointer relative flex items-center justify-center"
  aria-label="Switch to dark theme"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="w-6 h-6"
  >
    <circle
      id="theme-circle"
      cx="12"
      cy="12"
      r="9"
      fill="currentColor"
    />
    <g
      id="theme-rays"
      stroke="currentColor"
      style="opacity: 0; transform: scale(0.3); transform-origin: center; transition: opacity 0.3s, transform 0.3s;"
    >
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </g>
  </svg>
</button>

<script>
  import { initTheme } from "../scripts/theme.ts";

  initTheme();

  function syncIcon() {
    const isDark = document.documentElement.classList.contains("dark");
    const btn = document.getElementById("theme-toggle-btn");
    const circle = document.getElementById("theme-circle");
    const rays = document.getElementById("theme-rays") as HTMLElement | null;
    if (!btn || !circle || !rays) return;

    circle.setAttribute("r", isDark ? "5" : "9");
    rays.style.opacity = isDark ? "1" : "0";
    rays.style.transform = isDark ? "scale(1)" : "scale(0.3)";
    btn.setAttribute(
      "aria-label",
      isDark ? "Switch to light theme" : "Switch to dark theme",
    );
  }

  function initToggleBtn() {
    const btn = document.getElementById("theme-toggle-btn");
    if (!btn) return;
    btn.addEventListener("click", () => {
      window.dispatchEvent(new Event("theme-toggle"));
    });
  }

  // Watch for class changes on <html> to keep icon in sync (e.g. theme-toggle event)
  new MutationObserver(syncIcon).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"],
  });

  document.addEventListener("astro:page-load", () => {
    syncIcon();
    initToggleBtn();
  });
</script>
